 */
 -->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <preference for="WeArePlanet\Payment\Api\PaymentMethodConfigurationRepositoryInterface" type="WeArePlanet\Payment\Model\PaymentMethodConfigurationRepository" />
    <preference for="WeArePlanet\Payment\Api\PaymentMethodConfigurationManagementInterface" type="WeArePlanet\Payment\Model\PaymentMethodConfigurationManagement" />
    <preference for="WeArePlanet\Payment\Api\Data\PaymentMethodConfigurationInterface" type="WeArePlanet\Payment\Model\PaymentMethodConfiguration" />
    <preference for="WeArePlanet\Payment\Api\Data\PaymentMethodConfigurationSearchResultsInterface" type="Magento\Framework\Api\SearchResults" />
    <preference for="WeArePlanet\Payment\Api\OrderRepositoryInterface" type="WeArePlanet\Payment\Model\OrderRepository" />
    <preference for="WeArePlanet\Payment\Api\TransactionInfoRepositoryInterface" type="WeArePlanet\Payment\Model\TransactionInfoRepository" />
    <preference for="WeArePlanet\Payment\Api\TransactionInfoManagementInterface" type="WeArePlanet\Payment\Model\TransactionInfoManagement" />
    <preference for="WeArePlanet\Payment\Api\Data\TransactionInfoInterface" type="WeArePlanet\Payment\Model\TransactionInfo" />
    <preference for="WeArePlanet\Payment\Api\Data\TransactionInfoSearchResultsInterface" type="Magento\Framework\Api\SearchResults" />
    <preference for="WeArePlanet\Payment\Api\TokenInfoRepositoryInterface" type="WeArePlanet\Payment\Model\TokenInfoRepository" />
    <preference for="WeArePlanet\Payment\Api\TokenInfoManagementInterface" type="WeArePlanet\Payment\Model\TokenInfoManagement" />
    <preference for="WeArePlanet\Payment\Api\Data\TokenInfoInterface" type="WeArePlanet\Payment\Model\TokenInfo" />
    <preference for="WeArePlanet\Payment\Api\Data\TokenInfoSearchResultsInterface" type="Magento\Framework\Api\SearchResults" />
    <preference for="WeArePlanet\Payment\Api\RefundJobRepositoryInterface" type="WeArePlanet\Payment\Model\RefundJobRepository" />
    <preference for="WeArePlanet\Payment\Api\Data\RefundJobInterface" type="WeArePlanet\Payment\Model\RefundJob" />
    <preference for="WeArePlanet\Payment\Api\Data\RefundJobSearchResultsInterface" type="Magento\Framework\Api\SearchResults" />
    <preference for="WeArePlanet\PluginCore\Log\LoggerInterface" type="WeArePlanet\Payment\Logger\PluginCoreLoggerAdapter" />
    <preference for="WeArePlanet\PluginCore\Settings\SettingsProviderInterface" type="WeArePlanet\Payment\Model\CoreWebhook\SettingsProvider" />
    <preference for="WeArePlanet\PluginCore\Webhook\StateFetcherInterface" type="WeArePlanet\Payment\Model\CoreWebhook\StateFetcher" />
    <preference for="WeArePlanet\PluginCore\Webhook\WebhookLifecycleHandler" type="WeArePlanet\Payment\Model\CoreWebhook\CompositeWebhookLifecycleHandler" />
    <type name="WeArePlanet\Payment\Model\ResourceModel\TokenInfo\Collection\Grid">
        <arguments>
            <argument name="resource" xsi:type="object">WeArePlanet\Payment\Model\ResourceModel\TokenInfo</argument>
        </arguments>
    </type>

    <type name="WeArePlanet\Payment\Model\Config\Structure\Reader">
        <arguments>
            <argument name="compiler" xsi:type="object">Magento\Framework\View\TemplateEngine\Xhtml\ConfigCompiler</argument>
        </arguments>
    </type>

    <type name="WeArePlanet\Payment\Model\Service\WebhookService">
        <arguments>
            <argument name="webhookListenerPool" xsi:type="object">WeArePlanetWebhookListenerPool</argument>
            <argument name="urlBuilder" xsi:type="object">Magento\Framework\Url</argument>
        </arguments>
    </type>

    <type name="WeArePlanet\Payment\Console\Command\SynchronizePaymentMethods">
        <arguments>
            <argument name="paymentMethodConfigurationManagement" xsi:type="object">WeArePlanet\Payment\Api\PaymentMethodConfigurationManagementInterface\Proxy</argument>
        </arguments>
    </type>

    <!-- Providers -->
    <type name="WeArePlanet\Payment\Model\Provider\PaymentMethodProvider">
        <arguments>
            <argument name="cache" xsi:type="object">Magento\Framework\App\Cache\Type\Config</argument>
        </arguments>
    </type>
    <type name="WeArePlanet\Payment\Model\Provider\PaymentConnectorProvider">
        <arguments>
            <argument name="cache" xsi:type="object">Magento\Framework\App\Cache\Type\Config</argument>
        </arguments>
    </type>
    <type name="WeArePlanet\Payment\Model\Provider\LanguageProvider">
        <arguments>
            <argument name="cache" xsi:type="object">Magento\Framework\App\Cache\Type\Config</argument>
        </arguments>
    </type>
    <type name="WeArePlanet\Payment\Model\Provider\LabelDescriptorProvider">
        <arguments>
            <argument name="cache" xsi:type="object">Magento\Framework\App\Cache\Type\Config</argument>
        </arguments>
    </type>
    <type name="WeArePlanet\Payment\Model\Provider\LabelDescriptorGroupProvider">
        <arguments>
            <argument name="cache" xsi:type="object">Magento\Framework\App\Cache\Type\Config</argument>
        </arguments>
    </type>
    <type name="WeArePlanet\Payment\Model\Provider\CurrencyProvider">
        <arguments>
            <argument name="cache" xsi:type="object">Magento\Framework\App\Cache\Type\Config</argument>
        </arguments>
    </type>

    <!-- Webhook Listeners -->
    <type name="Magento\Framework\Lock\Backend\Database">
        <arguments>
            <argument name="path" xsi:type="string">var/lock</argument>
        </arguments>
    </type>
    <type name="WeArePlanet\Payment\Model\Webhook\Listener\AbstractOrderRelatedListener">
        <arguments>
            <argument name="lockManager" xsi:type="object">Magento\Framework\Lock\Backend\Database</argument>
        </arguments>
    </type>
    <type name="WeArePlanet\Payment\Model\Webhook\Listener\TransactionListener">
        <arguments>
            <argument name="commandPool" xsi:type="object">WeArePlanetTransactionWebhookCommandPool</argument>
        </arguments>
    </type>
    <type name="WeArePlanet\Payment\Model\Webhook\Listener\TransactionInvoiceListener">
        <arguments>
            <argument name="commandPool" xsi:type="object">WeArePlanetTransactionInvoiceWebhookCommandPool</argument>
        </arguments>
    </type>
    <type name="WeArePlanet\Payment\Model\Webhook\Listener\DeliveryIndicationListener">
        <arguments>
            <argument name="commandPool" xsi:type="object">WeArePlanetDeliveryIndicationWebhookCommandPool</argument>
        </arguments>
    </type>
    <type name="WeArePlanet\Payment\Model\Webhook\Listener\TransactionCompletionListener">
        <arguments>
            <argument name="commandPool" xsi:type="object">WeArePlanetTransactionCompletionWebhookCommandPool</argument>
        </arguments>
    </type>
    <type name="WeArePlanet\Payment\Model\Webhook\Listener\RefundListener">
        <arguments>
            <argument name="commandPool" xsi:type="object">WeArePlanetRefundWebhookCommandPool</argument>
        </arguments>
    </type>

    <!-- Webhook Listener Pools -->
    <virtualType name="WeArePlanetWebhookListenerPool" type="WeArePlanet\Payment\Model\Webhook\ListenerPool">
        <arguments>
            <argument name="listeners" xsi:type="array">
                <item name="transaction" xsi:type="string">WeArePlanet\Payment\Model\Webhook\Listener\TransactionListener</item>
                <item name="transactioninvoice" xsi:type="string">WeArePlanet\Payment\Model\Webhook\Listener\TransactionInvoiceListener</item>
                <item name="deliveryindication" xsi:type="string">WeArePlanet\Payment\Model\Webhook\Listener\DeliveryIndicationListener</item>
                <item name="transactioncompletion" xsi:type="string">WeArePlanet\Payment\Model\Webhook\Listener\TransactionCompletionListener</item>
                <item name="refund" xsi:type="string">WeArePlanet\Payment\Model\Webhook\Listener\RefundListener</item>
                <item name="paymentmethodconfiguration" xsi:type="string">WeArePlanet\Payment\Model\Webhook\Listener\PaymentMethodConfigurationListener</item>
                <item name="manualtask" xsi:type="string">WeArePlanet\Payment\Model\Webhook\Listener\ManualTaskListener</item>
                <item name="token" xsi:type="string">WeArePlanet\Payment\Model\Webhook\Listener\TokenListener</item>
                <item name="tokenversion" xsi:type="string">WeArePlanet\Payment\Model\Webhook\Listener\TokenVersionListener</item>
            </argument>
        </arguments>
    </virtualType>
    <virtualType name="WeArePlanetTransactionWebhookCommandPool" type="WeArePlanet\Payment\Model\Webhook\Listener\CommandPool">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="authorized" xsi:type="string">WeArePlanet\Payment\Model\Webhook\Listener\Transaction\AuthorizedCommand</item>
                <item name="completed" xsi:type="string">WeArePlanet\Payment\Model\Webhook\Listener\Transaction\CompletedCommand</item>
                <item name="fulfill" xsi:type="string">WeArePlanet\Payment\Model\Webhook\Listener\Transaction\FulfillCommand</item>
                <item name="decline" xsi:type="string">WeArePlanet\Payment\Model\Webhook\Listener\Transaction\DeclineCommand</item>
                <item name="failed" xsi:type="string">WeArePlanet\Payment\Model\Webhook\Listener\Transaction\FailedCommand</item>
                <item name="voided" xsi:type="string">WeArePlanet\Payment\Model\Webhook\Listener\Transaction\VoidedCommand</item>
            </argument>
        </arguments>
    </virtualType>
    <virtualType name="WeArePlanetTransactionInvoiceWebhookCommandPool" type="WeArePlanet\Payment\Model\Webhook\Listener\CommandPool">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="paid" xsi:type="string">WeArePlanet\Payment\Model\Webhook\Listener\TransactionInvoice\CaptureCommand</item>
                <item name="not_applicable" xsi:type="string">WeArePlanet\Payment\Model\Webhook\Listener\TransactionInvoice\CaptureCommand</item>
            </argument>
        </arguments>
    </virtualType>
    <virtualType name="WeArePlanetDeliveryIndicationWebhookCommandPool" type="WeArePlanet\Payment\Model\Webhook\Listener\CommandPool">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="manual_check_required" xsi:type="string">WeArePlanet\Payment\Model\Webhook\Listener\DeliveryIndication\ManualCheckRequiredCommand</item>
            </argument>
        </arguments>
    </virtualType>
    <virtualType name="WeArePlanetTransactionCompletionWebhookCommandPool" type="WeArePlanet\Payment\Model\Webhook\Listener\CommandPool">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="failed" xsi:type="string">WeArePlanet\Payment\Model\Webhook\Listener\TransactionCompletion\FailedCommand</item>
            </argument>
        </arguments>
    </virtualType>
    <virtualType name="WeArePlanetRefundWebhookCommandPool" type="WeArePlanet\Payment\Model\Webhook\Listener\CommandPool">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="successful" xsi:type="string">WeArePlanet\Payment\Model\Webhook\Listener\Refund\SuccessfulCommand</item>
                <item name="failed" xsi:type="string">WeArePlanet\Payment\Model\Webhook\Listener\Refund\FailedCommand</item>
            </argument>
        </arguments>
    </virtualType>

    <!-- Payment Gateway -->
    <virtualType name="WeArePlanetPaymentGatewayCommandPool" type="Magento\Payment\Gateway\Command\CommandPool">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="initialize" xsi:type="string">WeArePlanet\Payment\Gateway\Command\InitializeCommand</item>
                <item name="capture" xsi:type="string">WeArePlanet\Payment\Gateway\Command\CaptureCommand</item>
                <item name="void" xsi:type="string">WeArePlanet\Payment\Gateway\Command\VoidCommand</item>
                <item name="refund" xsi:type="string">WeArePlanet\Payment\Gateway\Command\RefundCommand</item>
                <item name="cancel" xsi:type="string">WeArePlanet\Payment\Gateway\Command\VoidCommand</item>
                <item name="accept_payment" xsi:type="string">WeArePlanet\Payment\Gateway\Command\AcceptPaymentCommand</item>
                <item name="deny_payment" xsi:type="string">WeArePlanet\Payment\Gateway\Command\DenyPaymentCommand</item>
            </argument>
        </arguments>
    </virtualType>
    <virtualType name="WeArePlanetPaymentGatewayValidatorPool" type="Magento\Payment\Gateway\Validator\ValidatorPool">
        <arguments>
            <argument name="validators" xsi:type="array"></argument>
        </arguments>
    </virtualType>

    <!-- Plugins/Interceptors -->
    <type name="Magento\Config\Model\Config\Structure\Converter">
        <plugin name="weareplanet_payment_config_structure_converter" type="WeArePlanet\Payment\Plugin\Config\Model\Config\Structure\Converter" />
    </type>
    <type name="Magento\Framework\App\Config\Initial\Converter">
        <plugin name="weareplanet_payment_config_initial_converter" type="WeArePlanet\Payment\Plugin\Framework\App\Config\Initial\Converter" />
    </type>
    <type name="Magento\Payment\Model\Config\Reader">
        <plugin name="weareplanet_payment_payment_config_reader" type="WeArePlanet\Payment\Plugin\Payment\Model\Config\Reader" />
    </type>
    <type name="Magento\Payment\Model\Method\Factory">
        <plugin name="weareplanet_payment_payment_method_factory" type="WeArePlanet\Payment\Plugin\Payment\Model\Method\Factory" />
    </type>
    <type name="Magento\Checkout\Block\Checkout\LayoutProcessor">
        <plugin name="weareplanet_payment_checkout_layout_processor" type="WeArePlanet\Payment\Plugin\Checkout\Block\Checkout\LayoutProcessor" />
    </type>
    <type name="Magento\Sales\Model\Service\CreditmemoService">
        <plugin name="weareplanet_payment_sales_creditmemo_service" type="WeArePlanet\Payment\Plugin\Sales\Model\Service\CreditmemoService" />
    </type>
    <type name="Magento\Sales\Model\AdminOrder\Create">
        <plugin name="weareplanet_payment_sales_adminorder_create" type="WeArePlanet\Payment\Plugin\Sales\Model\AdminOrder\Create" />
    </type>
    <type name="Magento\Customer\Model\AccountManagement">
        <plugin name="weareplanet_payment_customer_accountmanagement" type="WeArePlanet\Payment\Plugin\Customer\Model\AccountManagement" />
    </type>
    <type name="Magento\Sales\Model\ResourceModel\Order\Handler\State">
        <plugin name="weareplanet_payment_sales_order_handler_state" type="WeArePlanet\Payment\Plugin\Sales\Model\ResourceModel\Order\Handler\State" />
    </type>

    <!-- Console Commands -->
    <type name="Magento\Framework\Console\CommandListInterface">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="synchronizePaymentMethodsCommand" xsi:type="object">WeArePlanet\Payment\Console\Command\SynchronizePaymentMethods</item>
            </argument>
        </arguments>
    </type>

    <type name="WeArePlanet\PluginCore\Settings\Settings">
        <arguments>
            <argument name="spaceId" xsi:type="number">12345</argument>
            <argument name="userId" xsi:type="number">67890</argument>
            <argument name="apiKey" xsi:type="string">dummy-key</argument>
        </arguments>
    </type>

    <type name="WeArePlanet\PluginCore\Sdk\SdkProvider">
        <arguments>
            <argument name="settings" xsi:type="object">WeArePlanet\PluginCore\Settings\Settings</argument>
        </arguments>
    </type>

    <virtualType name="WeArePlanet\Payment\TransactionGateway" type="WeArePlanet\PluginCore\Sdk\SdkV1\TransactionGateway">
        <arguments>
            <argument name="sdkProvider" xsi:type="object">WeArePlanet\PluginCore\Sdk\SdkProvider</argument>
            <argument name="logger" xsi:type="object">WeArePlanet\PluginCore\Log\LoggerInterface</argument>
            <argument name="settings" xsi:type="object">WeArePlanet\PluginCore\Settings\Settings</argument>
        </arguments>
    </virtualType>

    <type name="WeArePlanet\PluginCore\Webhook\DefaultStateFetcher">
        <arguments>
            <argument name="sdkProvider" xsi:type="object">WeArePlanet\PluginCore\Sdk\SdkProvider</argument>
            <argument name="settings" xsi:type="object">WeArePlanet\PluginCore\Settings\Settings</argument>
            <argument name="transactionGateway" xsi:type="object">WeArePlanet\Payment\TransactionGateway</argument>
        </arguments>
    </type>

    <type name="WeArePlanet\Payment\Logger\PluginCoreLoggerAdapter">
        <arguments>
            <argument name="logger" xsi:type="object">WeArePlanet\Payment\Logger\WebhookLogger</argument>
        </arguments>
    </type>

    <virtualType name="WeArePlanet\Payment\Logger\WebhookLogger" type="Magento\Framework\Logger\Monolog">
        <arguments>
            <argument name="name" xsi:type="string">weareplanet_webhook</argument>
            <argument name="handlers" xsi:type="array">
                <item name="system" xsi:type="object">WeArePlanet\Payment\Logger\Handler\Webhook</item>
            </argument>
        </arguments>
    </virtualType>

    <type name="WeArePlanet\Payment\Logger\Handler\Webhook">
        <arguments>
            <argument name="settings" xsi:type="object">WeArePlanet\PluginCore\Settings\Settings</argument>
            <argument name="filesystem" xsi:type="object">Magento\Framework\Filesystem\Driver\File</argument>
            <argument name="fileName" xsi:type="string">/var/log/weareplanet_webhook.log</argument>
        </arguments>
    </type>

    <type name="WeArePlanet\PluginCore\Webhook\WebhookProcessor">
        <arguments>
            <argument name="logger" xsi:type="object">WeArePlanet\Payment\Logger\PluginCoreLoggerAdapter</argument>
        </arguments>
    </type>

    <type name="WeArePlanet\Payment\Model\CoreWebhook\RegistryConfigurer">
        <arguments>
            <argument name="objectManager" xsi:type="object">Magento\Framework\ObjectManagerInterface\Proxy</argument>
            <argument name="webhookProcessor" xsi:type="object">WeArePlanet\PluginCore\Webhook\WebhookProcessor</argument>
        </arguments>
    </type>

    <type name="WeArePlanet\Payment\Model\CoreWebhook\CompositeWebhookLifecycleHandler">
        <arguments>
            <argument name="handlers" xsi:type="array">
                <item name="Transaction" xsi:type="object">WeArePlanet\Payment\Model\CoreWebhook\Transaction\TransactionWebhookLifecycleHandler</item>
                <item name="Refund" xsi:type="object">WeArePlanet\Payment\Model\CoreWebhook\Refund\RefundWebhookLifecycleHandler</item>
                <item name="DeliveryIndication" xsi:type="object">WeArePlanet\Payment\Model\CoreWebhook\DeliveryIndication\DeliveryIndicationWebhookLifecycleHandler</item>
                <item name="TransactionCompletion" xsi:type="object">WeArePlanet\Payment\Model\CoreWebhook\TransactionCompletion\TransactionCompletionWebhookLifecycleHandler</item>
                <item name="TransactionInvoice" xsi:type="object">WeArePlanet\Payment\Model\CoreWebhook\TransactionInvoice\TransactionInvoiceWebhookLifecycleHandler</item>
            </argument>

            <argument name="defaultHandler" xsi:type="object">WeArePlanet\Payment\Model\CoreWebhook\DefaultWebhookLifecycleHandler</argument>
        </arguments>
    </type>

    <type name="WeArePlanet\Payment\Model\CoreWebhook\Transaction\TransactionWebhookLifecycleHandler">
        <arguments>
            <argument name="logger" xsi:type="object">WeArePlanet\Payment\Logger\WebhookLogger</argument>
        </arguments>
    </type>


    <type name="WeArePlanet\Payment\Model\CoreWebhook\Refund\RefundWebhookLifecycleHandler">
        <arguments>
            <argument name="logger" xsi:type="object">WeArePlanet\Payment\Logger\WebhookLogger</argument>
        </arguments>
    </type>

    <type name="WeArePlanet\Payment\Model\CoreWebhook\DefaultWebhookLifecycleHandler">
        <arguments>
            <argument name="logger" xsi:type="object">WeArePlanet\Payment\Logger\WebhookLogger</argument>
        </arguments>
    </type>
    <type name="WeArePlanet\Payment\Model\CoreWebhook\DeliveryIndication\DeliveryIndicationWebhookLifecycleHandler">
        <arguments>
            <argument name="logger" xsi:type="object">WeArePlanet\Payment\Logger\WebhookLogger</argument>
        </arguments>
    </type>
    <type name="WeArePlanet\Payment\Model\CoreWebhook\TransactionCompletion\TransactionCompletionWebhookLifecycleHandler">
        <arguments>
            <argument name="logger" xsi:type="object">WeArePlanet\Payment\Logger\WebhookLogger</argument>
        </arguments>
    </type>
    <type name="WeArePlanet\Payment\Model\CoreWebhook\TransactionInvoice\TransactionInvoiceWebhookLifecycleHandler">
        <arguments>
            <argument name="logger" xsi:type="object">WeArePlanet\Payment\Logger\WebhookLogger</argument>
        </arguments>
    </type>
</config>
